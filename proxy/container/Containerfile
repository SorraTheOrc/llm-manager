# Base image: pick a small distro with podman-friendly tooling
FROM fedora:39

RUN dnf -y update && dnf -y install \
    python3 \
    python3-pip \
    which \
    curl \
    ca-certificates \
    && dnf clean all

# Create a non-root user for running the server inside the container
RUN useradd -m -s /bin/bash llama
WORKDIR /home/llama

# Copy start script and proxy helper scripts
COPY ../start-llama.sh /usr/local/bin/start-llama.sh
RUN chmod +x /usr/local/bin/start-llama.sh

# Default entrypoint runs the start script with any provided model
ENTRYPOINT ["/usr/local/bin/start-llama.sh"]

# Default command: print help
CMD ["--help"]
