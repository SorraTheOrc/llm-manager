##################################
Worklog Specific Ignores
##################################

# Ignore Worklog directory by default
.worklog/

# Keep defaults and plugins tracked
!.worklog/config.defaults.yaml
!.worklog/plugins/
!.worklog/plugins/**

# opencode temporary files
.opencode/tmp/

### End of Worklog Specific Ignores

##################################
# Editor/backup temp files
##################################
# Ignore files created by editors as backups that end with a tilde
# e.g. "file.txt~"
*~

# Python virtualenv
.venv/
